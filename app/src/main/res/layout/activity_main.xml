<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top bar with settings icon -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="test location"
                android:textSize="20sp"
                android:textColor="#212121"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnLanguage"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="中文"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:background="#9C27B0"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnSettings"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/settings"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:background="#757575"
                android:paddingStart="16dp"
                android:paddingEnd="16dp" />
        </LinearLayout>

        <!-- Status Card (hidden per user request) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="12dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvStatusTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/free_trial"
                android:textSize="22sp"
                android:textColor="@color/colorPrimary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTrialInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/trial_days_remaining_example"
                android:textSize="15sp"
                android:textColor="#757575"
                android:layout_marginTop="6dp" />

            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:max="15"
                android:progress="15" />
        </LinearLayout>

        <!-- Mock Status Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/mock_location_status"
                android:textSize="16sp"
                android:textColor="#212121"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvMockStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/not_started"
                android:textSize="14sp"
                android:textColor="#F44336"
                android:layout_marginTop="6dp" />

            <Button
                android:id="@+id/btnOpenMap"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/open_map"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:background="@color/colorPrimary"
                android:layout_marginTop="12dp" />
        </LinearLayout>

        <!-- Payment Button -->
        <Button
            android:id="@+id/btnPayment"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/add_usage_time"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:background="@color/green"
            android:layout_marginBottom="12dp" />

        <!-- Recent locations -->
        <LinearLayout
            android:id="@+id/recentLocationsPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/recent_mock_locations"
                android:textSize="16sp"
                android:textColor="#212121"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/recent_locations_hint"
                android:textSize="13sp"
                android:textColor="#757575"
                android:layout_marginTop="4dp" />

            <LinearLayout
                android:id="@+id/layoutRecent1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp">

                <TextView
                    android:id="@+id/tvRecent1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/no_recent_location_1"
                    android:textSize="14sp"
                    android:textColor="#333333" />

                <Button
                    android:id="@+id/btnStartRecent1"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:text="@string/start_mock"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:background="@color/colorPrimary"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutRecent2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="10dp">

                <TextView
                    android:id="@+id/tvRecent2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/no_recent_location_2"
                    android:textSize="14sp"
                    android:textColor="#333333" />

                <Button
                    android:id="@+id/btnStartRecent2"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:text="@string/start_mock"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:background="@color/colorPrimary"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutRecent3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="10dp">

                <TextView
                    android:id="@+id/tvRecent3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/no_recent_location_3"
                    android:textSize="14sp"
                    android:textColor="#333333" />

                <Button
                    android:id="@+id/btnStartRecent3"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:text="@string/start_mock"
                    android:textSize="14sp"
                    android:textColor="#FFFFFF"
                    android:background="@color/colorPrimary"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnStopRecentMock"
                android:layout_width="match_parent"
                android:layout_height="42dp"
                android:text="@string/stop_mock"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:background="#F44336"
                android:layout_marginTop="12dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvOfficialWebsite"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/official_website_footer"
            android:textSize="12sp"
            android:textColor="#757575"
            android:gravity="center"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="8dp" />

    </LinearLayout>
</ScrollView>
